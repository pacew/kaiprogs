#!/usr/bin/env bash
# bootstrap: one-time host setup for the kai tree
# Creates the directory structure, clones kaiprogs into the kai tree,
# and establishes the noexec bind mount.
# Safe to run more than once.
set -euo pipefail

KAI="${HOME}/kai"
FSTAB="/etc/fstab"
FSTAB_TAG="# kai noexec bind mount"

echo "=== kai bootstrap ==="

# Host git security config
echo "Configuring git..."
git config --global protocol.file.allow user
echo "  protocol.file.allow = user"

# Create directory structure
echo "Creating directory structure..."
mkdir -p "${KAI}/notes"
echo "  ${KAI}/notes"

# Clone kaiprogs into the kai tree (container's read-only copy)
KAIPROGS="${KAI}/kaiprogs"
if [ -d "${KAIPROGS}/.git" ]; then
    echo "  ${KAIPROGS} already exists, skipping clone"
else
    echo "Cloning kaiprogs into kai tree..."
    git clone https://github.com/pacew/kaiprogs.git "${KAIPROGS}"
    echo "  Cloned to ${KAIPROGS}"
fi

# Set up host claude memory symlink (MEMORY.md lives in kaiprogs repo)
HOST_MEMORY_DIR="${HOME}/.claude/projects/-home-pace-kaiprogs/memory"
HOST_MEMORY_LINK="${HOST_MEMORY_DIR}/MEMORY.md"
mkdir -p "${HOST_MEMORY_DIR}"
if [ -L "${HOST_MEMORY_LINK}" ]; then
    echo "  ${HOST_MEMORY_LINK} symlink already exists, skipping"
else
    ln -s "${HOME}/kaiprogs/MEMORY.md" "${HOST_MEMORY_LINK}"
    echo "  Created ${HOST_MEMORY_LINK}"
fi

# Pre-seed Claude Code config to skip the first-run onboarding wizard
CLAUDE_JSON="${KAI}/.claude.json"
if grep -q '"hasCompletedOnboarding"' "${CLAUDE_JSON}" 2>/dev/null; then
    echo "  ${CLAUDE_JSON} already has onboarding flag, skipping"
else
    echo "Pre-seeding Claude Code config..."
    printf '{"hasCompletedOnboarding":true}\n' > "${CLAUDE_JSON}"
    echo "  Created ${CLAUDE_JSON}"
fi

# Add fstab entry for persistence across reboots
if grep -qF "kai noexec bind mount" "${FSTAB}" 2>/dev/null; then
    echo "fstab entry already present, skipping"
else
    echo "Adding fstab entry..."
    printf '\n%s\n%s  %s  none  bind,noexec  0  0\n' \
        "${FSTAB_TAG}" "${KAI}" "${KAI}" \
        | sudo tee -a "${FSTAB}" > /dev/null
    echo "  Added to ${FSTAB}"
fi

# Apply the mount now, without waiting for reboot
if mountpoint -q "${KAI}"; then
    echo "${KAI} is already a mountpoint, skipping mount step"
else
    echo "Applying noexec bind mount..."
    sudo mount --bind "${KAI}" "${KAI}"
    sudo mount -o remount,noexec "${KAI}"
    echo "  Mounted"
fi

# Verify noexec is active
echo "Verifying..."
if findmnt --noheadings --output OPTIONS "${KAI}" | grep -q noexec; then
    echo "  OK: ${KAI} is noexec"
else
    echo "  ERROR: noexec not confirmed on ${KAI}" >&2
    findmnt "${KAI}" >&2
    exit 1
fi

echo "=== bootstrap complete ==="
echo ""
echo "Next steps:"
echo "  cd ${HOME}/kaiprogs && ./build-kai.sh   # build the container image"
echo "  ./run-kai.sh                            # enter the container"
